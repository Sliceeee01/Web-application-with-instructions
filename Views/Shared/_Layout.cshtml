<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GraSS Инструкции</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <!-- Зеленая шапка сайта -->
        <nav class="navbar navbar-expand-sm navbar-dark shadow-sm mb-4" style="background-color: #5da331;">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Instructions" asp-action="Index">
                    <!-- Логотип GraSS -->
                    <div class="bg-white text-success fw-bold rounded px-2 py-1 me-2" style="font-size: 1.2rem; letter-spacing: 1px;">GraSS</div>
                    <span class="fw-semibold">База инструкций</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Instructions" asp-action="Index">Все инструкции</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Instructions" asp-action="Create">Создать новую</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 bg-white py-3">
        <div class="container text-center">
            &copy; @DateTime.Now.Year — GraSS IT Support
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>