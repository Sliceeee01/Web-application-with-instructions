@model InstructiionsApp.Models.Instruction
@{ ViewData["Title"] = Model.Title; }

<div class="card shadow-sm mt-4">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0">@Model.Title</h3>
        <span class="badge bg-light text-dark fs-6">@Model.Category</span>
    </div>
    <div class="card-body">
        <p class="text-muted mb-4">
            <strong>Создано:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm") <br />
            <strong>Описание:</strong> @Model.Description
        </p>
        
        <h4 class="text-primary border-bottom pb-2">Текст инструкции:</h4>
<div class="bg-light p-4 border rounded shadow-sm">
    @Html.Raw(Model.Content)
</div>
        <div class="bg-light p-3 border rounded mb-4" style="white-space: pre-wrap;">@Model.Content</div>
        
        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            <h4 class="text-primary border-bottom pb-2 mt-4">Прикреплённые файлы и скриншоты:</h4>
            <div class="row mt-3">
                @foreach (var file in Model.Attachments)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card h-100 border-secondary">
                            @if (file.FileType != null && file.FileType.StartsWith("image/"))
                            {
                                <img src="@file.FilePath" class="card-img-top" alt="@file.FileName" style="height: 200px; object-fit: contain; background: #e9ecef; padding: 10px;">
                            }
                            <div class="card-body text-center d-flex flex-column justify-content-between bg-light">
                                <h6 class="card-title text-truncate" title="@file.FileName">@file.FileName</h6>
                                <a href="@file.FilePath" download="@file.FileName" class="btn btn-sm btn-outline-primary mt-2">Скачать файл</a>
                            </div>
                        </div>
                    </div>  
                }
            </div>
        }
    </div>
   <div class="card-footer text-muted d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактировать</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Удалить</a>
            <a asp-action="ExportToJson" asp-route-id="@Model.Id" class="btn btn-info text-white">Экспорт в JSON</a>
        </div>
    </div>
</div>
</div>