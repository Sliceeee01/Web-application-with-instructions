@model IEnumerable<InstructiionsApp.Models.Instruction>

@{
    ViewData["Title"] = "Список инструкций";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Рабочие инструкции</h2>
    <a asp-action="Create" class="btn btn-success">Создать новую</a>
</div>

<form asp-controller="Instructions" asp-action="Index" method="get" class="mb-4 p-3 bg-light border rounded shadow-sm">
    <div class="row g-2 align-items-center">
        <div class="col-md-5">
            <input type="text" name="searchString" class="form-control" placeholder="Поиск по названию или тексту..." value="@ViewContext.HttpContext.Request.Query["searchString"]" />
        </div>
        <div class="col-md-4">
            <select name="searchCategory" class="form-select">
                <option value="">-- Все категории --</option>
                <option value="Принтеры" selected="@(ViewContext.HttpContext.Request.Query["searchCategory"] == "Принтеры" ? "selected" : null)">Принтеры</option>
                <option value="Сканеры" selected="@(ViewContext.HttpContext.Request.Query["searchCategory"] == "Сканеры" ? "selected" : null)">Сканеры</option>
                <option value="ТСД" selected="@(ViewContext.HttpContext.Request.Query["searchCategory"] == "ТСД" ? "selected" : null)">ТСД</option>
                <option value="1С" selected="@(ViewContext.HttpContext.Request.Query["searchCategory"] == "1С" ? "selected" : null)">1С</option>
                <option value="Windows" selected="@(ViewContext.HttpContext.Request.Query["searchCategory"] == "Windows" ? "selected" : null)">Windows</option>
                <option value="Сеть" selected="@(ViewContext.HttpContext.Request.Query["searchCategory"] == "Сеть" ? "selected" : null)">Сеть</option>
                <option value="Офисные программы" selected="@(ViewContext.HttpContext.Request.Query["searchCategory"] == "Офисные программы" ? "selected" : null)">Офисные программы</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Найти</button>
        </div>
        <div class="col-md-1">
            <a asp-action="Index" class="btn btn-outline-secondary w-100" title="Сбросить фильтры">✖</a>
        </div>
    </div>
</form>
@if (!Model.Any())
{
    <div class="alert alert-info">Инструкций по вашему запросу не найдено.</div>
}
else
{
    <div class="list-group">
        @foreach (var item in Model)
        {
            <a asp-action="Details" asp-route-id="@item.Id" class="list-group-item list-group-item-action mb-2 border rounded shadow-sm">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1 text-primary">@item.Title</h5>
                    <small class="text-muted">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                </div>
                <p class="mb-1">@item.Description</p>
                <span class="badge bg-secondary">@item.Category</span>
            </a>
        }
    </div>
}