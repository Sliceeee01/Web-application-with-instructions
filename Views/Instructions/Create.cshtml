@model InstructiionsApp.Models.Instruction
@{ ViewData["Title"] = "Создать инструкцию"; }

<h2>Добавление новой инструкции</h2>
<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" enctype="multipart/form-data">
            <div class="mb-3">
                <label asp-for="Title" class="form-label font-weight-bold"></label>
                <input asp-for="Title" class="form-control" placeholder="Например: Как подключить принтер" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Category" class="form-label font-weight-bold"></label>
                <select asp-for="Category" class="form-select">
                    <option value="">-- Выберите категорию --</option>
                    <option value="Принтеры">Принтеры</option>
                    <option value="Сканеры">Сканеры</option>
                    <option value="ТСД">ТСД</option>
                    <option value="1С">1С</option>
                    <option value="Windows">Windows</option>
                    <option value="Сеть">Сеть</option>
                    <option value="Офисные программы">Офисные программы</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label font-weight-bold"></label>
                <input asp-for="Description" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label font-weight-bold"></label>
                <textarea asp-for="Content" class="form-control" rows="8" placeholder="Шаг 1. Сделайте..."></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            
            <div class="mb-4 p-3 border rounded bg-light">
                <label class="form-label font-weight-bold text-primary">Прикрепить файлы и скриншоты</label>
                <input type="file" name="uploadedFiles" class="form-control" multiple accept=".png,.jpg,.jpeg,.pdf,.docx,.txt,.zip" />
                <div class="form-text">Максимальный размер: 20 МБ. Разрешены: картинки, документы и архивы.</div>
            </div>
            
            <button type="submit" class="btn btn-primary">Сохранить</button>
            <a asp-action="Index" class="btn btn-secondary">Отмена</a>
        </form>
    </div>
</div>