@model InstructiionsApp.Models.Instruction
@{ ViewData["Title"] = "Создать инструкцию"; }

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<h2>Создать инструкцию</h2>
<hr />
<form asp-action="Create" enctype="multipart/form-data" id="instructionForm">
    <div class="mb-3">
        <label asp-for="Title" class="form-label font-weight-bold"></label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Category" class="form-label font-weight-bold"></label>
        <select asp-for="Category" class="form-select">
            <option value="Windows">Windows</option>
            <option value="Принтеры">Принтеры</option>
            <option value="Сеть">Сеть</option>
            <option value="1С">1С</option>
        </select>
    </div>
    
    <div class="mb-3">
        <label class="form-label font-weight-bold">Текст инструкции</label>
        <div id="editor" style="height: 300px; background: white;"></div>
        <input type="hidden" asp-for="Content" id="hiddenContent" />
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>

<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>
    var quill = new Quill('#editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, false] }],
                ['bold', 'italic', 'underline'],
                ['image', 'code-block']
            ]
        }
    });

    document.getElementById('instructionForm').onsubmit = function() {
        document.getElementById('hiddenContent').value = quill.root.innerHTML;
    };
</script>